{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "云音乐",
  "version": "0.1.0",
  "identifier": "com.r19988088.wyyyy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "云音乐",
        "width": 430,
        "height": 820,
        "minWidth": 360,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; media-src 'self' https: blob:; connect-src ipc: http://ipc.localhost https:; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "versionCode": 1
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
